#!/usr/bin/env bash

set -euo pipefail

require_cmd() {
    if ! command -v "$1" >/dev/null 2>&1; then
        echo "Missing required command: $1" >&2
        exit 1
    fi
}

ensure_op_signin() {
    if op whoami >/dev/null 2>&1; then
        return
    fi

    echo "No active 1Password CLI session found. Starting sign-in..."
    op signin

    if ! op whoami >/dev/null 2>&1; then
        echo "1Password sign-in completed, but no active session is available to this shell." >&2
        echo "If your setup requires a session token export, run: eval \$(op signin)" >&2
        exit 1
    fi
}

set_secret() {
    local name="$1"
    local value="$2"

    local cmd=(gh secret set "$name" -R "$REPO")

    if [[ "$DRY_RUN" == "1" ]]; then
        echo "[dry-run] would set $name in repo $REPO to: $value"
        return
    fi

    printf '%s' "$value" | "${cmd[@]}"
    echo "Set $name"
}

REPO="mblayman/homeschool"
VAULT_PATH="school-desk/server"
DRY_RUN="${DRY_RUN:-0}"

if [[ $# -ne 0 ]]; then
    echo "This script does not take CLI options. Edit REPO/VAULT_PATH in the script if needed." >&2
    exit 1
fi

require_cmd gh
require_cmd op

if [[ "$DRY_RUN" != "1" ]]; then
    gh auth status >/dev/null
fi

ensure_op_signin

CI_SECRETS=(
    CI_KAMAL_REGISTRY_PASSWORD
    CI_SSH_PRIVATE_KEY
    CI_AWS_ACCESS_KEY_ID
    CI_AWS_SECRET_ACCESS_KEY
    CI_DJSTRIPE_WEBHOOK_SECRET
    CI_HASHID_FIELD_SALT
    CI_ROLLBAR_ACCESS_TOKEN
    CI_SECRET_KEY
    CI_SENTRY_DSN
    CI_STRIPE_LIVE_PUBLISHABLE_KEY
    CI_STRIPE_LIVE_SECRET_KEY
    CI_STRIPE_TEST_PUBLISHABLE_KEY
    CI_STRIPE_TEST_SECRET_KEY
    CI_TURNSTILE_SITE_KEY
    CI_TURNSTILE_SECRET_KEY
)

echo "Syncing ${#CI_SECRETS[@]} secrets from op://$VAULT_PATH to GitHub..."

for ci_name in "${CI_SECRETS[@]}"; do
    op_field="${ci_name#CI_}"
    value="$(op read "op://$VAULT_PATH/$op_field")"
    set_secret "$ci_name" "$value"
done

echo "Sync complete."
