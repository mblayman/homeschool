#!/usr/bin/env bash

set -euo pipefail

ROOT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")/.." && pwd)"
DB_DIR="$ROOT_DIR/.e2e/db"
BASE_URL="http://127.0.0.1:8000"
PLAYWRIGHT_BIN="$ROOT_DIR/frontend/node_modules/.bin/playwright"

export ALLOWED_HOSTS='*'
export AWS_ACCESS_KEY_ID='a secret to everybody'
export AWS_SECRET_ACCESS_KEY='a secret to everybody'
export DJSTRIPE_WEBHOOK_SECRET='whsec_asecrettoeverybody'
export DJSTRIPE_WEBHOOK_VALIDATION=''
export HASHID_FIELD_SALT='a secret to everybody'
export IS_SECURE='off'
export SECRET_KEY='a secret to everybody'
export SENTRY_ENABLED='off'
export SENTRY_DSN='dsn_example'
export STRIPE_LIVE_MODE='off'
export STRIPE_LIVE_SECRET_KEY='sk_live_asecrettoeverybody'
export STRIPE_TEST_SECRET_KEY='sk_test_asecrettoeverybody'
export STRIPE_TEST_PUBLISHABLE_KEY='pk_test_asecrettoeverybody'
export DEBUG='True'
export DB_DIR
export DJANGO_SETTINGS_MODULE='project.settings'

mkdir -p "$DB_DIR"

if [[ ! -x "$PLAYWRIGHT_BIN" ]]; then
    echo "Playwright is not installed. Run: npm --prefix frontend install && npm --prefix frontend run e2e:install" >&2
    exit 1
fi

uv run manage.py migrate > "$ROOT_DIR/.e2e/migrate.log" 2>&1

uv run manage.py shell -c "from django.contrib.auth import get_user_model; U=get_user_model(); u,_=U.objects.get_or_create(username='e2e-admin', defaults={'email':'e2e@example.com'}); u.is_staff=True; u.is_superuser=True; u.set_password('e2e-password'); u.save()" > "$ROOT_DIR/.e2e/seed.log" 2>&1

uv run manage.py runserver 127.0.0.1:8000 --noreload > "$ROOT_DIR/.e2e/server.log" 2>&1 &
SERVER_PID=$!
trap 'kill $SERVER_PID 2>/dev/null || true' EXIT

ready=0
for i in {1..60}; do
    if ! kill -0 "$SERVER_PID" 2>/dev/null; then
        echo "Django server exited before becoming ready. See $ROOT_DIR/.e2e/server.log" >&2
        exit 1
    fi

    if curl -fsS "$BASE_URL/" >/dev/null 2>&1; then
        ready=1
        break
    fi

    sleep 1
done

if [[ "$ready" != "1" ]]; then
    echo "Timed out waiting for local server at $BASE_URL. See $ROOT_DIR/.e2e/server.log" >&2
    exit 1
fi

E2E_BASE_URL="$BASE_URL" "$PLAYWRIGHT_BIN" test --config "$ROOT_DIR/frontend/playwright.config.js" "$@"
