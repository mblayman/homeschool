#!/usr/bin/env bash

set -euo pipefail

ROOT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")/.." && pwd)"
BASE_URL="http://127.0.0.1:8000"
CONTAINER_NAME="homeschool-e2e"
PLAYWRIGHT_BIN="$ROOT_DIR/frontend/node_modules/.bin/playwright"

if [[ $# -lt 1 ]]; then
    echo "Usage: bin/e2e-docker <image-ref> [playwright args...]" >&2
    exit 1
fi

IMAGE_TAG="$1"
shift

cd "$ROOT_DIR"

mkdir -p "$ROOT_DIR/.e2e"

if [[ ! -x "$PLAYWRIGHT_BIN" ]]; then
    echo "Playwright is not installed. Run: npm --prefix frontend install && npm --prefix frontend run e2e:install" >&2
    exit 1
fi

docker rm -f "$CONTAINER_NAME" >/dev/null 2>&1 || true

docker run -d \
    --name "$CONTAINER_NAME" \
    -p 127.0.0.1:8000:8000 \
    -e ALLOWED_HOSTS='*' \
    -e AWS_ACCESS_KEY_ID='a secret to everybody' \
    -e AWS_SECRET_ACCESS_KEY='a secret to everybody' \
    -e DB_DIR='/app' \
    -e DJSTRIPE_WEBHOOK_SECRET='whsec_asecrettoeverybody' \
    -e DJSTRIPE_WEBHOOK_VALIDATION='' \
    -e HASHID_FIELD_SALT='a secret to everybody' \
    -e IS_SECURE='off' \
    -e SECRET_KEY='a secret to everybody' \
    -e SENTRY_ENABLED='off' \
    -e SENTRY_DSN='dsn_example' \
    -e STRIPE_LIVE_MODE='off' \
    -e STRIPE_LIVE_SECRET_KEY='sk_live_asecrettoeverybody' \
    -e STRIPE_TEST_SECRET_KEY='sk_test_asecrettoeverybody' \
    -e STRIPE_TEST_PUBLISHABLE_KEY='pk_test_asecrettoeverybody' \
    "$IMAGE_TAG" >/dev/null

trap 'docker rm -f "$CONTAINER_NAME" >/dev/null 2>&1 || true' EXIT

ready=0
for i in {1..60}; do
    running_container="$(docker ps --filter "name=^${CONTAINER_NAME}$" --format '{{.Names}}')"
    if [[ "$running_container" != "$CONTAINER_NAME" ]]; then
        echo "E2E container exited before becoming ready." >&2
        docker logs "$CONTAINER_NAME" || true
        exit 1
    fi

    if curl -fsS "$BASE_URL/" >/dev/null 2>&1; then
        ready=1
        break
    fi

    sleep 1
done

if [[ "$ready" != "1" ]]; then
    echo "Timed out waiting for containerized app at $BASE_URL" >&2
    docker logs "$CONTAINER_NAME" || true
    exit 1
fi

docker exec "$CONTAINER_NAME" python manage.py shell -c "from django.contrib.auth import get_user_model; U=get_user_model(); u,_=U.objects.get_or_create(username='e2e-admin', defaults={'email':'e2e@example.com'}); u.is_staff=True; u.is_superuser=True; u.set_password('e2e-password'); u.save()" >/dev/null

E2E_BASE_URL="$BASE_URL" "$PLAYWRIGHT_BIN" test --config "$ROOT_DIR/frontend/playwright.config.js" "$@"
