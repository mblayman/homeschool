# Secrets defined here are available for reference under registry/password, env/secret, builder/secrets,
# and accessories/*/env/secret in config/deploy.yml. All secrets should be pulled from either
# password manager, ENV, or a file. DO NOT ENTER RAW CREDENTIALS HERE! This file needs to be safe for git.

# Docker build
KAMAL_REGISTRY_PASSWORD=$(if [ -n "\$CI_KAMAL_REGISTRY_PASSWORD" ]; then printf "%s" "\$CI_KAMAL_REGISTRY_PASSWORD"; else op read op://school-desk/server/KAMAL_REGISTRY_PASSWORD; fi)
SSH_PRIVATE_KEY=$(if [ -n "\$CI_SSH_PRIVATE_KEY" ]; then printf "%s" "\$CI_SSH_PRIVATE_KEY"; elif op read op://school-desk/server/SSH_PRIVATE_KEY >/dev/null 2>&1; then op read op://school-desk/server/SSH_PRIVATE_KEY; elif [ -f "$HOME/.ssh/id_ed25519" ]; then cat "$HOME/.ssh/id_ed25519"; elif [ -f "$HOME/.ssh/id_rsa" ]; then cat "$HOME/.ssh/id_rsa"; else printf ""; fi)

